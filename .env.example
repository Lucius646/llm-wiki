# LLM Wiki Configuration

# LLM Provider: openai or anthropic
LLM_PROVIDER=openai

# API Key for your chosen provider
API_KEY=your-api-key-here

# Model name to use
MODEL_NAME=gpt-4o

# Wiki root directory (default: current directory)
# WIKI_ROOT=/path/to/your/wiki

# Enable auto Git commit (true/false, default: true)
# GIT_AUTO_COMMIT=true

# Whisper model for audio transcription (tiny, base, small, medium, large)
# WHISPER_MODEL=base
